{
  "description": "Lifecycle hooks for tracking and cleaning up idle ACP bridges per Claude Code session, plus background job watcher for async notifications",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/session-hook.sh\" start",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/job-watcher.sh\"",
            "asyncRewake": true,
            "rewakeMessage": "ACP job watcher daemon",
            "timeout": 86400
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/inject-pending.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/session-hook.sh\" end",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
